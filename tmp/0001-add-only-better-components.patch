new file mode 100755
--- /dev/null
+++ b/scripts/scan-zh.sh
@@ -0,0 +1,9 @@
+#!/usr/bin/env bash
+set -euo pipefail
+shopt -s globstar
+found=0
+grep -R -nP '[\x{4e00}-\x{9fff}]' --include='*.{ts,tsx,md,mdx}' app src || found=$?
+if [[ $found -eq 0 ]]; then
+  echo "Chinese chars found. Please remove before commit." >&2
+  exit 1
+fi