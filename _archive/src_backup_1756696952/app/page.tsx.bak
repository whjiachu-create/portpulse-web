/** -------------------- Trend widget -------------------- **/
type TrendApiPoint = {
  ts?: string | number;
  t?: string | number;
  date?: string;
  v?: number;
  congestion_score?: number;
  value?: number;
};

function TrendMini({
  unlocode,
  days = 7,
  height = 224,
}: {
  unlocode: string;
  days?: number;
  height?: number;
}) {
  const [data, setData] = useState<Pt[] | null>(null);
  const [err, setErr] = useState<string | null>(null);

  useEffect(() => {
    const url = `${API_BASE}/v1/ports/${unlocode}/trend?days=${days}`;
    fetch(url, { headers: { "X-API-Key": DEMO_KEY }, cache: "no-store" })
      .then(async (r) => {
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        const j = await r.json();
        const pts: Pt[] = (Array.isArray(j.points) ? j.points : []).map((p: TrendApiPoint) => {
          const ts = p.ts ?? p.t ?? p.date ?? "";
          const v =
            typeof p.v === "number"
              ? p.v
              : typeof p.congestion_score === "number"
              ? p.congestion_score
              : typeof p.value === "number"
              ? p.value
              : 0;
          return { ts, v };
        });
        setData(pts);
      })
      .catch((e) => setErr(String(e)));
  }, [unlocode, days]);

  return (
    <div style={{ height }} className="rounded-lg border bg-white p-3">
      {err && (
        <div className="flex h-full items-center justify-center text-sm text-red-600">
          Failed to load: {err}
        </div>
      )}
      {!data && !err && (
        <div className="flex h-full items-center justify-center text-sm text-gray-500">
          Loading…
        </div>
      )}
      {data && (
        <ResponsiveContainer width="100%" height="100%">
          <LineChart data={data}>
            <XAxis
              dataKey="ts"
              tickFormatter={(t) => {
                const d = new Date(t);
                const mm = String(d.getMonth() + 1).padStart(2, "0");
                const dd = String(d.getDate()).padStart(2, "0");
                return `${mm}/${dd}`;
              }}
              stroke="#9CA3AF"
              tickMargin={8}
            />
            <YAxis stroke="#9CA3AF" width={48} />
            <Tooltip labelFormatter={(t) => new Date(t as number).toLocaleString()} />
            <Line type="monotone" dataKey="v" stroke="#111827" strokeWidth={2} dot={false} />
          </LineChart>
        </ResponsiveContainer>
      )}
    </div>
  );
}
