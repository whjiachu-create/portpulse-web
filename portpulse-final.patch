+"use client";
+import Script from "next/script";
+
+export default function Analytics() {
+  const gaId = process.env.NEXT_PUBLIC_GA_ID;
+  const clarityId = process.env.NEXT_PUBLIC_CLARITY_ID;
+  const prod = process.env.NODE_ENV === "production";
+
+  if (!prod) return null;
+
+  return (
+    <>
+      {gaId && (
+        <>
+          <Script src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} strategy="lazyOnload" />
+          <Script id="ga-init" strategy="lazyOnload">
+            {`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}
+gtag('js', new Date()); gtag('config', '${gaId}', { anonymize_ip: true });`}
+          </Script>
+        </>
+      )}
+      {clarityId && (
+        <Script id="clarity-init" strategy="lazyOnload">
+          {`(function(c,l,a,r,i,t,y){ c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
+t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
+y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window, document, "clarity", "script", "${clarityId}");`}
+        </Script>
+      )}
+    </>
+  );
+}
diff --git a/src/components/D3WorldPortsMap.tsx b/src/components/D3WorldPortsMap.tsx
new file mode 100644
index 0000000..a3b51d2
--- /dev/null
+++ b/src/components/D3WorldPortsMap.tsx
@@ -0,0 +1,143 @@
+"use client";
+
+import { useEffect, useMemo, useState } from "react";
+import { geoNaturalEarth1, geoPath, GeoProjection } from "d3-geo";
+import { feature } from "topojson-client";
+
+type CountryFeature = GeoJSON.Feature<GeoJSON.Geometry, GeoJSON.GeoJsonProperties>;
+type Countries = CountryFeature[];
+
+const PORTS = [
+  { name: "Los Angeles", unlocode: "USLAX", lat: 33.74, lon: -118.27 },
+  { name: "New York",     unlocode: "USNYC", lat: 40.67, lon:  -74.04 },
+  { name: "Singapore",    unlocode: "SGSIN", lat:  1.264, lon: 103.84 },
+];
+
+export default function D3WorldPortsMap() {
+  const [countries, setCountries] = useState<Countries>([]);
+  const [tip, setTip] = useState<{ x: number; y: number; text: string } | null>(null);
+
+  const width = 960, height = 520;
+  const projection: GeoProjection = useMemo(
+    () => geoNaturalEarth1().translate([width / 2, height / 2]).scale(165),
+    []
+  );
+  const path = useMemo(() => geoPath(projection), [projection]);
+
+  useEffect(() => {
+    let ok = true;
+    (async () => {
+      try {
+        const res = await fetch("https://unpkg.com/world-atlas@2/countries-110m.json", { cache: "force-cache" });
+        const topo = await res.json();
+        const fc = feature(topo, topo.objects.countries) as GeoJSON.FeatureCollection;
+        if (ok) setCountries(fc.features as Countries);
+      } catch {
+        if (ok) setCountries([]); // 降级：不画底图，只画端口
+      }
+    })();
+    return () => { ok = false; };
+  }, []);
+
+  const toXY = (lon: number, lat: number) => projection([lon, lat]) as [number, number];
+
+  return (
+    <div className="relative">
+      <style jsx>{`
+        @keyframes pulse {
+          0% { transform: scale(0.9); opacity: 0.6; }
+          50% { transform: scale(1.25); opacity: 0.15; }
+          100% { transform: scale(1.4); opacity: 0; }
+        }
+      `}</style>
+      <svg viewBox={`0 0 ${width} ${height}`} className="w-full h-auto rounded-2xl border border-black/5 bg-white">
+        <g>
+          {countries.map((c, i) => (
+            <path key={i} d={path(c as any) || ""} className="fill-[#DCE7F1] stroke-white/50" />
+          ))}
+        </g>
+        <g>
+          {PORTS.map((p) => {
+            const [x, y] = toXY(p.lon, p.lat);
+            const r = 3.5;
+            return (
+              <g
+                key={p.unlocode}
+                transform={`translate(${x}, ${y})`}
+                onMouseEnter={(e) => {
+                  const rect = (e.currentTarget.ownerSVGElement as SVGSVGElement).getBoundingClientRect();
+                  setTip({ x: e.clientX - rect.left + 10, y: e.clientY - rect.top + 10, text: `${p.name} (${p.unlocode})` });
+                }}
+                onMouseLeave={() => setTip(null)}
+                cursor="pointer"
+              >
+                <circle r={r * 2.2} className="fill-[#26B1FF]" style={{ opacity: 0.12 }} />
+                <circle r={r * 2.2} className="fill-[#26B1FF]" style={{ animation: "pulse 2.2s ease-out infinite" }} />
+                <circle r={r} className="fill-[#0B2740] stroke-white" />
+              </g>
+            );
+          })}
+        </g>
+      </svg>
+      {tip && (
+        <div
+          className="absolute z-10 pointer-events-none rounded-lg bg-[#0B2740] text-white text-xs px-2 py-1 shadow"
+          style={{ left: tip.x, top: tip.y }}
+        >
+          {tip.text}
+        </div>
+      )}
+    </div>
+  );
+}
