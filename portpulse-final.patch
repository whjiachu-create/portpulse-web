+/* Finalized contact page with business-email validation and mailto fallback */
+"use client";
+
+import { useState } from "react";
+import isBusinessEmail from "@/lib/isBusinessEmail";
+
+export default function ContactPage() {
+  const [form, setForm] = useState({ name: "", email: "", company: "", message: "" });
+  const [error, setError] = useState<string>("");
+  const [ok, setOk] = useState<boolean | null>(null);
+
+  const mailto = `mailto:support@useportpulse.com?subject=PortPulse%20Inquiry&body=${encodeURIComponent(
+    JSON.stringify(form, null, 2)
+  )}`;
+
+  async function onSubmit(e: React.FormEvent) {
+    e.preventDefault();
+    setError(""); setOk(null);
+
+    if (!isBusinessEmail(form.email)) {
+      setError("请使用工作邮箱，我们将优先处理来自公司域的请求。");
+      return;
+    }
+
+    try {
+      const res = await fetch("/api/contact", {
+        method: "POST",
+        headers: { "Content-Type": "application/json" },
+        body: JSON.stringify(form),
+      });
+      setOk(res.ok);
+      if (!res.ok) window.location.href = mailto;
+    } catch {
+      window.location.href = mailto;
+    }
+  }
+
+  return (
+    <div className="container mx-auto px-4 py-12 md:py-16">
+      <h1 className="text-3xl font-semibold tracking-tight">Contact</h1>
+      <p className="mt-2 text-black/60">Tell us about your use case. We typically reply within 1 business day.</p>
+
+      <form onSubmit={onSubmit} className="mt-8 grid gap-6 max-w-2xl">
+        <div className="grid gap-2">
+          <label className="text-sm font-medium">Name</label>
+          <input
+            className="rounded-xl border border-black/10 px-3 py-2 outline-none focus:ring-2 ring-[#26B1FF]"
+            value={form.name}
+            onChange={(e) => setForm((s) => ({ ...s, name: e.target.value }))}
+            required
+          />
+        </div>
+
+        <div className="grid gap-2">
+          <label className="text-sm font-medium">Work Email</label>
+          <input
+            type="email"
+            className="rounded-xl border border-black/10 px-3 py-2 outline-none focus:ring-2 ring-[#26B1FF]"
+            value={form.email}
+            onChange={(e) => setForm((s) => ({ ...s, email: e.target.value }))}
+            required
+          />
+          {error && <p className="text-sm text-red-600">{error}</p>}
+        </div>
+
+        <div className="grid gap-2">
+          <label className="text-sm font-medium">Company</label>
+          <input
+            className="rounded-xl border border-black/10 px-3 py-2 outline-none focus:ring-2 ring-[#26B1FF]"
+            value={form.company}
+            onChange={(e) => setForm((s) => ({ ...s, company: e.target.value }))}
+          />
+        </div>
+
+        <div className="grid gap-2">
+          <label className="text-sm font-medium">Message</label>
+          <textarea
+            rows={5}
+            className="rounded-xl border border-black/10 px-3 py-2 outline-none focus:ring-2 ring-[#26B1FF]"
+            value={form.message}
+            onChange={(e) => setForm((s) => ({ ...s, message: e.target.value }))}
+          />
+        </div>
+
+        <div className="flex gap-3">
+          <button className="rounded-xl bg-[#0B2740] text-white px-5 py-2 hover:opacity-90 transition">Submit</button>
+          <button
+            type="button"
+            onClick={() => navigator.clipboard.writeText(JSON.stringify(form, null, 2))}
+            className="rounded-xl border border-black/10 px-5 py-2 hover:bg-black/5 transition"
+            title="Copy current JSON"
+          >
+            Copy JSON
+          </button>
+          <a href={mailto} className="rounded-xl border border-black/10 px-5 py-2 hover:bg-black/5 transition">
+            Fallback: Mail
+          </a>
+        </div>
+
+        {ok === true && <p className="text-green-600 text-sm">Submitted. We’ll get back to you shortly.</p>}
+        {ok === false && <p className="text-red-600 text-sm">Submission failed. Fallback mail link opened.</p>}
+      </form>
+    </div>
+  );
+}
