+        show-method-in-nav="as-colored-block"
+        show-components="true"
+        use-path-in-nav-bar="true"
+        schema-style="tree"
+        api-key-name="X-API-Key"
+        api-key-location="header"
+      ></rapi-doc>
+    </div>
+  );
+}
