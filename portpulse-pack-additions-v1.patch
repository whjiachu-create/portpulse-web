+    <div className="container mx-auto px-2 md:px-4 py-4 md:py-8">
+      <Script src="https://unpkg.com/rapidoc/dist/rapidoc-min.js" strategy="lazyOnload" />
+      <rapi-doc
+        spec-url={specUrl}
+        render-style="read"
+        theme="light"
+        show-header="false"
+        primary-color="#0B2740"
+        nav-bg-color="#ffffff"
+        nav-text-color="#0B2740"
